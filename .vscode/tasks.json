{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar projeto",
            "command": "g++",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "${workspaceFolder}/cpp/main.cpp",
                "${workspaceFolder}/cpp/CalculadoraAlbum.cpp",
                "-o",
                "${workspaceFolder}/cpp/output/main"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}